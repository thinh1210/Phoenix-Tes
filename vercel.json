{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/(.*\\.(?:js|css|png|jpg|svg|ico|woff2?)$)",
      "dest": "client/dist/$1"
    },
    {
      "src": "/(.*)",
      "status": 200,
      "dest": "client/dist/index.html"
    }
  ]
}